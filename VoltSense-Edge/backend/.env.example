# VoltSense Edge Backend Configuration

# Server settings
PORT=3000

# MQTT Settings
MQTT_BROKER_URL=mqtt://broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=voltsense/data

# Firebase Admin SDK Configuration
# Path to your Firebase service account JSON key file (absolute path or relative to backend directory)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Enable simulation mode (true/false)
# If true, backend will mock MQTT client and Firebase Firestore writes if they fail or are unconfigured.
USE_SIMULATION=true
